generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               Int      @id @default(autoincrement())
  name             String
  shortDescription String
  description      String
  price            Int
  salePrice        Int?
  discountPercent  Int      @default(0)
  sku              String?
  brand            String?
  stock            Int      @default(0)
  status           String   @default("published")
  highlights       String[]
  tags             String[]
  weight           Float?
  sizes            String[]
  colors           String[]
  images           Json
  sellerEmail      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  categorySlug     String
  category         Category @relation(fields: [categorySlug], references: [slug])
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  products Product[]
}
